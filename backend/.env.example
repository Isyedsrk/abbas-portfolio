# Copy to .env and fill in. Do not commit .env.

# Optional: huggingface | openai | ollama
# AI_PROVIDER=huggingface
# Use local Ollama first, or after cloud fails:
# AI_PROVIDER=ollama
# OLLAMA_FALLBACK=1

HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Optional: more varied / natural completions (Ollama, Hugging Face router, OpenAI)
# LLM_TEMPERATURE=0.75
# LLM_TOP_P=0.92

OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Local Ollama (free; install from https://ollama.com)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Server (Render sets PORT automatically)
# PORT=3000
